# GEMINI_API_KEY: Optional - Tier 0 (best quality, 1500 req/day free tier)
# Sign up at https://aistudio.google.com/
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# VITE_GROQ_API_KEY: Optional - Tier 1 (free, ~14400 req/day, LLaMA 4 Vision)
# Sign up FREE at https://console.groq.com/ — no credit card required
VITE_GROQ_API_KEY="YOUR_GROQ_API_KEY"

# VITE_OPENROUTER_API_KEY: Optional - Tier 2 (free, LLaMA 3.2 Vision)
# Sign up FREE at https://openrouter.ai/ — no credit card required
VITE_OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# NOTE: At least ONE key is recommended for best quality.
# If NO keys are set, the app falls back to Tesseract.js offline OCR (no API needed).
